{
  "title": "Recovery index: 2019 = 100",
  "data": {
    "url": "data/recovery_index.csv"
  },
  "transform": [
    {
      "filter": "datum.year <= 2025 || datum.metric == 'Visa lodgements'"
    }
  ],
  "mark": {
    "type": "line",
    "point": {
      "filled": true,
      "size": 55
    },
    "strokeWidth": 3
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": null,
      "axis": {
        "labelAngle": 0
      }
    },
    "y": {
      "field": "index_2019_100",
      "type": "quantitative",
      "title": "Index (2019 = 100)"
    },
    "color": {
      "field": "metric",
      "type": "nominal",
      "scale": {
        "range": [
          "#0f766e",
          "#b45309",
          "#7c3aed",
          "#be123c"
        ]
      }
    },
    "tooltip": [
      {
        "field": "year"
      },
      {
        "field": "metric"
      },
      {
        "field": "index_2019_100",
        "title": "Index"
      }
    ]
  },
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, system-ui, sans-serif",
      "titleFont": "Inter, system-ui, sans-serif",
      "gridColor": "#e7e2d9",
      "domainColor": "#c9c1b4",
      "tickColor": "#c9c1b4",
      "labelColor": "#302c25",
      "titleColor": "#302c25"
    },
    "legend": {
      "labelFont": "Inter, system-ui, sans-serif",
      "titleFont": "Inter, system-ui, sans-serif",
      "labelColor": "#302c25",
      "titleColor": "#302c25"
    },
    "title": {
      "font": "Fraunces, Georgia, serif",
      "fontSize": 16,
      "color": "#302c25",
      "anchor": "start"
    }
  }
}