{
  "title": "International student enrolments, Victoria",
  "data": {
    "url": "data/vic_international_education_yearly.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "area",
        "line": {
          "color": "#0f766e",
          "strokeWidth": 3
        },
        "color": "#99f6e4",
        "opacity": 0.85
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": null
        },
        "y": {
          "field": "enrolments",
          "type": "quantitative",
          "title": "Enrolments",
          "axis": {
            "format": "~s"
          }
        },
        "tooltip": [
          {
            "field": "year"
          },
          {
            "field": "enrolments",
            "format": ","
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "middle",
        "dx": 8,
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#0f766e"
      },
      "transform": [
        {
          "filter": "datum.year == 2024 || datum.year == 2025"
        }
      ],
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "enrolments",
          "type": "quantitative"
        },
        "text": {
          "field": "enrolments",
          "format": ","
        }
      }
    }
  ],
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, system-ui, sans-serif",
      "titleFont": "Inter, system-ui, sans-serif",
      "gridColor": "#e7e2d9",
      "domainColor": "#c9c1b4",
      "tickColor": "#c9c1b4",
      "labelColor": "#302c25",
      "titleColor": "#302c25"
    },
    "legend": {
      "labelFont": "Inter, system-ui, sans-serif",
      "titleFont": "Inter, system-ui, sans-serif",
      "labelColor": "#302c25",
      "titleColor": "#302c25"
    },
    "title": {
      "font": "Fraunces, Georgia, serif",
      "fontSize": 16,
      "color": "#302c25",
      "anchor": "start"
    }
  }
}