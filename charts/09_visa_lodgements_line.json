{
  "title": "Offshore primary student visa lodgements, February YTD",
  "data": {
    "url": "data/student_visa_lodgements_feb_ytd.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "line",
        "point": {
          "filled": true,
          "size": 65
        },
        "strokeWidth": 3,
        "color": "#be123c"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "title": null
        },
        "y": {
          "field": "offshore_primary_student_visas_lodged_feb_ytd",
          "type": "quantitative",
          "title": "Visa lodgements",
          "axis": {
            "format": "~s"
          }
        },
        "tooltip": [
          {
            "field": "year"
          },
          {
            "field": "offshore_primary_student_visas_lodged_feb_ytd",
            "format": ","
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year == 2026"
        }
      ],
      "mark": {
        "type": "text",
        "dx": 10,
        "align": "left",
        "fontWeight": "bold",
        "color": "#be123c"
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal"
        },
        "y": {
          "field": "offshore_primary_student_visas_lodged_feb_ytd",
          "type": "quantitative"
        },
        "text": {
          "field": "offshore_primary_student_visas_lodged_feb_ytd",
          "format": ","
        }
      }
    }
  ],
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Inter, system-ui, sans-serif",
      "titleFont": "Inter, system-ui, sans-serif",
      "gridColor": "#e7e2d9",
      "domainColor": "#c9c1b4",
      "tickColor": "#c9c1b4",
      "labelColor": "#302c25",
      "titleColor": "#302c25"
    },
    "legend": {
      "labelFont": "Inter, system-ui, sans-serif",
      "titleFont": "Inter, system-ui, sans-serif",
      "labelColor": "#302c25",
      "titleColor": "#302c25"
    },
    "title": {
      "font": "Fraunces, Georgia, serif",
      "fontSize": 16,
      "color": "#302c25",
      "anchor": "start"
    }
  }
}